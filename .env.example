# ============================================================
#  GoTravel Mart — configuration
#  Copy this file to ".env" and fill in your values.
#  The app runs fine with blanks (CRM & WhatsApp go to "log-only"
#  mode so you can see exactly what *would* be sent).
# ============================================================

PORT=3000

# ---- Admin panel ----
# The single password used to log in at /admin/
ADMIN_PASSWORD=admin123

# ---- Your CRM API ----
# Every enquiry is POSTed here as JSON. Leave CRM_API_URL blank to log-only.
CRM_API_URL=
CRM_API_KEY=
# Header used to send the key, and an optional value prefix.
# e.g. Authorization + "Bearer "  ->  Authorization: Bearer <key>
#      x-api-key     + ""         ->  x-api-key: <key>
CRM_AUTH_HEADER=Authorization
CRM_AUTH_PREFIX=Bearer

# ---- WhatsApp (Meta Cloud API) ----
# Leave WHATSAPP_TOKEN blank to log-only. To go live, create a Meta
# Business app, add WhatsApp, get a permanent token + phone number id,
# and get the two templates below approved in WhatsApp Manager.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_CONFIRM_TEMPLATE=appointment_confirmation
WHATSAPP_REMINDER_TEMPLATE=appointment_reminder

# How many minutes before the appointment the reminder is sent.
REMINDER_LEAD_MINUTES=120

# Default country code prepended to 10-digit phone numbers.
DEFAULT_COUNTRY_CODE=91

# ---- Amadeus (flights + hotels) ----
# Free keys from https://developers.amadeus.com  (Self-Service, test environment).
# Leave blank to run in DEMO mode (realistic sample results, no live calls).
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# test | production  (test = free sandbox)
AMADEUS_ENV=test
# Currency for fare/room search
AMADEUS_CURRENCY=INR

# ---- Razorpay (payments) ----
# Test keys are instant from the Razorpay dashboard. Blank = MOCK mode
# (payment is simulated as successful so the booking flow is testable).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
